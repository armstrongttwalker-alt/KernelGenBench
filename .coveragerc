# Coverage.py configuration file
# Run with: pytest --cov=src --cov-report=html
# Or: pytest --cov=src --cov-report=term-missing

[run]
# Source code directories to measure
source = src

# Files to omit from coverage
omit =
    */test/*
    */tests/*
    */old_bench/*
    */__pycache__/*
    */site-packages/*
    */dist-packages/*
    setup.py
    */conftest.py

# Branch coverage (measure if/else branches)
branch = True

# Parallel mode for multiprocessing tests
parallel = False

[report]
# Precision for coverage percentage
precision = 2

# Show missing lines in terminal report
show_missing = True

# Skip covered files in report
skip_covered = False

# Skip empty files
skip_empty = True

# Lines to exclude from coverage
exclude_lines =
    # Standard pragma
    pragma: no cover

    # Don't complain about missing debug code
    def __repr__
    def __str__

    # Don't complain if tests don't hit defensive assertion code
    raise AssertionError
    raise NotImplementedError

    # Don't complain if non-runnable code isn't run
    if __name__ == .__main__.:
    if __name__ == "__main__":

    # Don't complain about abstract methods
    @abstract
    @abstractmethod

    # Don't complain about type checking code
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:

    # Don't complain about pass statements
    pass

    # Don't complain about ellipsis
    \.\.\.

# Ignore errors from source code that can't be found
ignore_errors = False

[html]
# Directory for HTML report
directory = htmlcov

# Title for HTML report
title = KernelGenBench Coverage Report

[xml]
# Output file for XML report (for CI/CD)
output = coverage.xml

[json]
# Output file for JSON report
output = coverage.json
# Pretty print JSON
pretty_print = True
